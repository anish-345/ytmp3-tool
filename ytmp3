#!/bin/bash
#
# 🎵 YouTube to MP3 Converter - ULTIMATE Standalone Edition
#

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Find binaries in multiple locations
find_binary() {
    local name=$1
    for dir in "$SCRIPT_DIR" "$SCRIPT_DIR/binaries" "$HOME/.local/share/ytmp3" "/opt/ytmp3"; do
        if [ -f "$dir/$name" ]; then
            echo "$dir/$name"
            return
        fi
    done
    echo "$name"  # Fall back to PATH
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUTPUT_DIR="$HOME/storage/downloads"
mkdir -p "$OUTPUT_DIR"

FFMPEG=$(find_binary ffmpeg)
DENO=$(find_binary deno)

echo -e "${BLUE}🎵 YouTube to MP3 Converter - Standalone Edition${NC}"
echo -e "${BLUE}================================================${NC}"

# Parse arguments
URL=""
OUTPUT_NAME="audio"

while [[ $# -gt 0 ]]; do
    case $1 in
        -u=*|--url=*) URL="${arg#*=}"; shift ;;
        -u|--url) URL="$2"; shift 2 ;;
        -o=*|--output=*) OUTPUT_NAME="${arg#*=}"; shift ;;
        -o|--output) OUTPUT_NAME="$2"; shift 2 ;;
        --clipboard)
            URL=$(termux-clipboard-get 2>/dev/null | tr -d '\n')
            shift ;;
        -h|--help)
            echo "Usage: $0 [OPTIONS] [URL]"
            echo "  -u, --url     YouTube URL"
            echo "  -o, --output  Output filename"
            echo "  --clipboard   Use clipboard URL"
            exit 0 ;;
        *)
            [ -z "$URL" ] && URL="$1"
            shift ;;
    esac
done

[ -z "$URL" ] && { echo -e "${RED}Error: No URL${NC}"; exit 1; }

echo -e "${GREEN}URL: $URL${NC}"
echo -e "${GREEN}Output: $OUTPUT_DIR/${OUTPUT_NAME}.mp3${NC}"
echo

# Use system Python + yt-dlp (fastest method)
if command -v python3 &>/dev/null && python3 -c "import yt_dlp" 2>/dev/null; then
    python3 -m yt_dlp \
        -x --audio-format mp3 --audio-quality 0 \
        --ffmpeg-location "$FFMPEG" \
        -o "$OUTPUT_DIR/$OUTPUT_NAME.%(ext)s" \
        "$URL"
# Fallback: bundled ffmpeg only (download first, convert manually)
elif command -v curl &>/dev/null && [ -f "$FFMPEG" ]; then
    echo -e "${BLUE}📥 Downloading audio stream...${NC}"
    # This requires additional implementation
    echo -e "${RED}Full standalone requires Python or JS runtime${NC}"
    echo "Install: pkg install python && pip install yt-dlp"
    exit 1
else
    echo -e "${RED}Error: No downloader available${NC}"
    exit 1
fi

echo -e "${GREEN}✅ Done! Saved to $OUTPUT_DIR${NC}"
