#!/bin/bash

# YouTube to MP3 Converter Tool
# Properly encodes to actual MP3 format
# Uses bundled dependencies (ffmpeg, yt-dlp, deno)

OUTPUT_DIR="$HOME/storage/downloads"

# Find dependencies in order of preference:
# 1. Bundled with app (./ffmpeg, ./yt-dlp, ./deno)
# 2. System installed (Termux or other)

# Set paths for bundled dependencies
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Use bundled dependencies if they exist
if [ -f "$SCRIPT_DIR/ffmpeg" ]; then
    FFMPEG="$SCRIPT_DIR/ffmpeg"
    YT_DLP="$SCRIPT_DIR/yt-dlp"
    DENO="$SCRIPT_DIR/deno"
else
    # Fall back to system
    FFMPEG="ffmpeg"
    YT_DLP="yt-dlp"
    DENO="deno"
fi

# Create downloads directory if it doesn't exist
mkdir -p "$OUTPUT_DIR"

echo "🎵 YouTube to MP3 Converter"
echo "=========================="

# Check if URL is provided
if [ -z "$1" ]; then
    echo "Usage: ytmp3 <youtube-url>"
    echo "Example: ytmp3 https://youtu.be/xxxxx"
    exit 1
fi

URL="$1"

echo "📥 Downloading and converting..."
echo "Please wait..."

# Use yt-dlp with ffmpeg to create actual MP3 file
# Pass the bundled executables
"$YT_DLP" -x \
       --ffmpeg-location "$FFMPEG" \
       --audio-format mp3 \
       --audio-quality 0 \
       --output "$OUTPUT_DIR/%(title)s.%(ext)s" \
       --js-runtimes deno \
       --deno-location "$DENO" \
       "$URL"

if [ $? -eq 0 ]; then
    echo ""
    echo "✅ Success! File saved to: $OUTPUT_DIR"
    echo ""
    # List the downloaded file
    echo "📁 Downloaded files:"
    ls -lh "$OUTPUT_DIR"/*.mp3 2>/dev/null | tail -1
else
    echo ""
    echo "❌ Error occurred during conversion"
fi