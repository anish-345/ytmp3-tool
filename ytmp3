#!/bin/bash
#
# 🎵 YouTube to MP3 Converter - Standalone Edition
# Python + yt-dlp bundled (12 MB total)
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUTPUT_DIR="$HOME/storage/downloads"
mkdir -p "$OUTPUT_DIR"

echo -e "\033[0;34m🎵 YouTube to MP3 Converter\033[0m"
echo -e "\033[0;34m==============================\033[0m"

# Get URL from args
URL=""
for arg in "$@"; do
    if [[ "$arg" =~ ^https?:// ]]; then
        URL="$arg"
        break
    fi
done

[ -z "$URL" ] && { echo "Usage: $0 <youtube-url>"; exit 1; }

echo -e "\033[0;32mURL: $URL\033[0m"
echo -e "\033[0;32mOutput: $OUTPUT_DIR\033[0m"
echo

# Run bundled Python executable (includes Python + yt-dlp)
"$SCRIPT_DIR/ytmp3-bin" --output-dir "$OUTPUT_DIR" "$URL" 2>/dev/null || \
"$SCRIPT_DIR/ytmp3-bin" "$URL"
